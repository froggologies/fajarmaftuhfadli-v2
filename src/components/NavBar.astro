---
import Link from "@/components/Link.astro";
---

<nav class="flex h-20 items-center justify-between p-7">
  <div class="logo-container text-2xl font-black">
    <Link underline={false}>
      <a
        href="/"
        class="inline-flex items-center transition-transform duration-300 hover:scale-110 active:scale-95"
      >
        <span class="f-mirrored inline-block">F</span>
        <span class="m-letter inline-block">M</span>
        <span class="f-letter inline-block">F</span>
      </a>
    </Link>
  </div>
  <ul class="flex space-x-4 font-semibold [&_a]:text-slate-400">
    <li>
      <Link underline={false} color={false}
        ><a href="/background">Background</a></Link
      >
    </li>
    <li>
      <Link underline={false} color={false}
        ><a href="/projects">Projects</a></Link
      >
    </li>
    <li>
      <Link underline={false} color={false}><a href="/skills">Skills</a></Link>
    </li>
  </ul>
</nav>

<style>
  .logo-container a {
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }

  .f-mirrored {
    transform: scaleX(-1);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .m-letter,
  .f-letter {
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .logo-container a:hover .f-mirrored {
    transform: scaleX(-1) translateY(-4px) rotate(-10deg);
  }

  .logo-container a:hover .m-letter {
    transform: translateY(-6px);
  }

  .logo-container a:hover .f-letter {
    transform: translateY(-4px) rotate(10deg);
  }
</style>
