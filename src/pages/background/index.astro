---
import Layout from "@/layouts/Layout.astro";

import BackgroundItem from "@/components/BackgroundItem.astro";
import Container from "@/components/Container.astro";
import H1 from "@/components/H1.astro";
import H1Subtext from "@/components/H1Subtext.astro";
import H2 from "@/components/H2.astro";
import Link from "@/components/Link.astro";
import Ul from "@/components/Ul.astro";
---

<Layout title="Background - Fajar Maftuh Fadli">
  <Container>
    <H1>Background</H1>
    <H1Subtext>
      Here's a summary of my professional background and education.
    </H1Subtext>
    <section>
      <div class="mb-8">
        <H2>Experience</H2>
        <div class="flex flex-col gap-3">
          <BackgroundItem
            organization="PT FISClouds Innovations"
            organizationUrl="https://www.fisclouds.com"
            title="DevOps Engineer"
            location="South Jakarta, Remote"
            startDate="Sep 2022"
            endDate="Present"
          >
            <p class="text-slate-300">Key Responsibilities</p>
            <Ul>
              <li>
                Designed and developed Proofs of Concept (POC) for clients.
              </li>
              <li>Estimated GCP billing and optimized cost efficiency.</li>
              <li>
                Provided technical support and troubleshooting for client
                environments.
              </li>
            </Ul>
            <p class="text-slate-300">Selected Projects:</p>
            <div>
              <p class="text-slate-300">BerandaToko (Jatis Mobile)</p>
              <Ul>
                <li>
                  Integrated monitoring and logging on GCP using New Relic.
                </li>
              </Ul>
            </div>
            <div>
              <p class="text-slate-300">Bank CIMB</p>
              <Ul>
                <li>
                  Automated IAM provisioning for hundreds of BigQuery datasets
                  and tables using Terraform, applying least-privilege
                  principles.
                </li>
                <li>
                  Developed Looker Studio dashboards and alerting for BigQuery
                  usage.
                </li>
                <li>
                  Authored TSD and FSD documentation for GCP implementations.
                </li>
              </Ul>
            </div>
            <div>
              <p class="text-slate-300">Biz2X</p>
              <Ul>
                <li>Integrated PagerDuty with GCP alert notifications.</li>
                <li>
                  Deployed VM monitoring agents and built alerting dashboards.
                </li>
              </Ul>
            </div>
            <div>
              <p class="text-slate-300">Bank Danamon</p>
              <Ul>
                <li>
                  Conducted on-premise database assessment and designed ETL
                  pipelines connecting PostgreSQL, Oracle, and MySQL to BigQuery
                  via Data Fusion.
                </li>
                <li>
                  Managed and automated GCP resources (VMs, Cloud Composer, Data
                  Fusion) with Terraform.
                </li>
                <li>
                  Built centralized logging, metrics, and alerting systems
                  across the organization.
                </li>
                <li>
                  Developed automated notification workflows using Pub/Sub,
                  Cloud Functions, Secret Manager, and integrations with
                  Telegram and Microsoft Teams.
                </li>
                <li>
                  Wrote landing zone TSD and validation test cases for service
                  reliability.
                </li>
              </Ul>
            </div>
          </BackgroundItem>
        </div>
      </div>
    </section>

    <section>
      <div>
        <H2>Education</H2>
        <div class="flex flex-col gap-3">
          <BackgroundItem
            organization="University of Gunadarma"
            organizationUrl="https://www.gunadarma.ac.id"
            title="Informatics Engineering"
            location="Depok"
            startDate="Aug 2018"
            endDate="Sep 2024"
          >
            <Ul>
              <li>
                Achieved GPA: <span class="text-slate-300">3.63/4.00</span>
              </li>
              <li>
                Relevant Coursework: Software Engineering, Cloud Computing,
                Network Administration.
              </li>
              <li>
                Final Project: Securing Websites Using Terraform and Cloud Armor
                on Google Cloud Platform.
              </li>
            </Ul>
          </BackgroundItem>
          <BackgroundItem
            organization="Bangkit"
            organizationUrl="https://www.linkedin.com/company/bangkit-academy/"
            title="Cloud Computing Path Student"
            location="Remote"
            startDate="Feb 2022"
            endDate="Jul 2022"
          >
            <p class="italic">
              Bangkit is a unique career readiness program led by Google and
              delivered with support from industry experts from industry
              partners like GoTo and Traveloka.
            </p>
            <p>
              Participated successfully in Bangkit 2022 and was awarded <span
                class="text-slate-300">Graduate Distinction</span
              >. The final average score I achieved was <span
                class="text-slate-300">96.45</span
              >. As part of the Company-Based Capstone Project team for
              <Link
                ><a
                  href="https://kitabisa.com"
                  target="_blank"
                  rel="noopener noreferrer">Kitabisa</a
                ></Link
              >, we developed the On-Demand Ambulance Application, which is used
              to call the nearest ambulance in emergency situations. Our team
              was also selected as the best team at the Bangkit Company Capstone
              Project in collaboration with Kitabisa.
            </p>
            <p>Complete various courses and assignments:</p>
            <Ul>
              <li>Web Development</li>
              <li>Javascript</li>
              <li>Back-End with Google Cloud</li>
              <li>Google Cloud Computing Foundations</li>
              <li>Google Cloud Skills Boost Quests</li>
              <li>Architecting with Google Compute Engine</li>
            </Ul>
          </BackgroundItem>
        </div>
      </div>
    </section>
  </Container>
</Layout>
