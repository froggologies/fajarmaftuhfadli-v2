---
import Layout from "@/layouts/Layout.astro";

import IconArrowBadgeRight from "@/components/icons/arrow-badge-right.astro";
import IconExclamationCircle from "@/components/icons/exclamation-circle.astro";

import Link from "@/components/Link.astro";
---

<Layout title="404">
  <div class="mx-auto max-w-2xl font-mono">
    <h1
      class="text-stroke-outside mb-3 -space-x-24 text-9xl font-black text-red-400"
    >
      <span class="">4</span>
      <span class="">0</span>
      <span class="">4</span>
    </h1>
    <p class="flex items-center gap-2">
      <span class="text-red-400">
        <IconExclamationCircle />
      </span>
      <span id="status-text">Error: Page not found</span>
    </p>
    <p id="status-detail" class="mb-3">
      <span id="path-display"></span>/index.html : No such file or directory
    </p>
    <div class="flex items-center gap-2">
      <IconArrowBadgeRight />
      <Link
        ><a href="/" class="group relative"
          >cd /home<span
            class="animate-blink absolute top-0 -right-[1ch] bottom-0 w-1 bg-gray-400 group-hover:bg-blue-400"
          ></span></a
        >
      </Link>
    </div>
  </div>
</Layout>

<script>
  const updatePaths = () => {
    const pathString = window.location.pathname;
    const is404Route = pathString === "/404" || pathString === "/404/";

    const statusText = document.getElementById("status-text");
    const statusDetail = document.getElementById("status-detail");

    if (is404Route) {
      if (statusText) statusText.textContent = "Success: 404 page found";
      if (statusDetail) statusDetail.textContent = "Hi! Are you lost?";
    } else {
      const pathDisplay = document.getElementById("path-display");
      if (pathDisplay) {
        pathDisplay.textContent = pathString;
      }
    }
  };

  // Run on initial load and navigation
  updatePaths();
  document.addEventListener("astro:page-load", updatePaths);
</script>

<style>
  .text-stroke {
    -webkit-text-stroke-color: #fff;
    -webkit-text-stroke-width: 2px;
  }

  .text-stroke-outside {
    text-shadow:
      1px 0 0 black,
      -1px 0 0 black,
      0 1px 0 black,
      0 -1px 0 black,
      2px 0 0 black,
      -2px 0 0 black,
      0 2px 0 black,
      0 -2px 0 black,
      3px 0 0 black,
      -3px 0 0 black,
      0 3px 0 black,
      0 -3px 0 black,
      4px 0 0 black,
      -4px 0 0 black,
      0 4px 0 black,
      0 -4px 0 black,
      1px 1px 0 black,
      -1px 1px 0 black,
      1px -1px 0 black,
      -1px -1px 0 black,
      2px 2px 0 black,
      -2px 2px 0 black,
      2px -2px 0 black,
      -2px -2px 0 black,
      3px 3px 0 black,
      -3px 3px 0 black,
      3px -3px 0 black,
      -3px -3px 0 black,
      4px 4px 0 black,
      -4px 4px 0 black,
      4px -4px 0 black,
      -4px -4px 0 black;
  }

  .animate-blink {
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
