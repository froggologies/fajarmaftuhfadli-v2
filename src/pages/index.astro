---
import Layout from "@/layouts/Layout.astro";

import IconBrandGithub from "@/components/icons/brand-github.astro";
import IconBrandLinkedin from "@/components/icons/brand-linkedin.astro";
import IconBrandSteam from "@/components/icons/brand-steam.astro";
import IconMail from "@/components/icons/mail.astro";
import IconWavingHand from "@/components/icons/waving-hand.astro";

import Button from "@/components/Button.astro";
import Container from "@/components/Container.astro";
import H1 from "@/components/H1.astro";
import Link from "@/components/Link.astro";
import Spacer from "@/components/Spacer.astro";
---

<Layout title="Fajar Maftuh Fadli">
  <Container>
    <H1>Fajar Maftuh Fadli</H1>
    <div class="mb-8 space-y-2">
      <p>
        <span class="flex items-center gap-2">
          Hey! I'm Fajar<span
            class="origin-[70%_70%] animate-wave cursor-grab [&>svg]:h-6 [&>svg]:w-6 [&>svg]:fill-slate-100 [&>svg]:hover:fill-blue-400 [&>svg]:active:fill-blue-400"
            ><IconWavingHand /></span
          >
        </span>
        a DevOps engineer who cares about clean, reliable infrastructure.
      </p>
      <ul class="flex items-center gap-2">
        <li>
          <Button
            ><a
              href="https://rxresu.me/fajarmaftuhfadli/dev-ops-engineer"
              target="_blank"
              rel="noopener noreferrer">View CV</a
            ></Button
          >
        </li>
        <li><Button><a href="/#contact">Contact Me</a></Button></li>
      </ul>
    </div>
    <div class="space-y-5">
      <p>
        I'm currently working at <Link
          ><a
            href="https://www.fisclouds.com"
            target="_blank"
            rel="noopener noreferrer">FISClouds</a
          ></Link
        >, where I design and manage cloud systems—mostly on Google Cloud
        Platform. I work a lot with Terraform to automate infrastructure, handle
        IAM at scale, and setting up monitoring and alerting so things stay
        reliable and predictable in production.
      </p>
      <p>
        Most of my experience comes from real production environments, so I care
        a lot about reliability, cost efficiency, and making systems easy to
        observe and maintain.
      </p>
      <p>
        Outside of that, I've been getting into frontend and web development,
        mainly in the JavaScript ecosystem. It's fun designing things—lining
        everything up, making them interactive, and building something that
        actually looks good, not just infrastructure hidden somewhere in the
        cloud.
      </p>
      <p>
        When I'm not working, I'm usually gaming, watching movies or series, or
        ricing my <Link
          ><a href="https://github.com/froggologies/dotfiles">setup</a></Link
        >.
      </p>
    </div>
    <Spacer />
    <div id="contact">
      <p>You can find me here:</p>
      <ul class="flex gap-4">
        <li>
          <Link>
            <a
              href="https://github.com/froggologies"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2"
            >
              <IconBrandGithub />
              GitHub
            </a>
          </Link>
        </li>
        <li>
          <Link>
            <a
              href="https://www.linkedin.com/in/fajarmaftuhfadli"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2"
            >
              <IconBrandLinkedin />
              LinkedIn
            </a>
          </Link>
        </li>
        <li>
          <Link>
            <a
              href="https://steamcommunity.com/id/froggologies"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2"
            >
              <IconBrandSteam />
              Steam
            </a>
          </Link>
        </li>
      </ul>
      <p class="flex items-center gap-2">
        Or mail me at <Link
          ><a
            href="mailto:fajarmaftuhfadli@gmail.com"
            class="flex items-center gap-2"
            ><IconMail />fajarmaftuhfadli@gmail.com</a
          ></Link
        >
      </p>
    </div>
  </Container>
</Layout>
