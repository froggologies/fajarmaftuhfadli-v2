---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
---

<Layout title="Credits - Fajar Maftuh Fadli">
  <Section>
    <div class="space-y-6">
      <h1 class="mb-4 text-4xl font-black text-slate-50">Credits</h1>
      <p>
        A huge thanks to the open-source community for the tools and
        inspirations that helped build this site.
      </p>
      <ul class="list-inside list-disc space-y-2 marker:text-slate-600">
        <li>
          Design inspired by <a
            href="https://antfu.me"
            target="_blank"
            rel="noopener noreferrer">Anthony Fu</a
          >.
        </li>
        <li>
          Icons by <a
            href="https://tabler.io/icons"
            target="_blank"
            rel="noopener noreferrer">Tabler Icons</a
          > and <a
            href="https://www.svgrepo.com/svg/364573/hand-waving-fill"
            target="_blank"
            rel="noopener noreferrer">Phosphor</a
          >.
        </li>
        <li>
          Background animation using <a
            href="https://github.com/bramus/css-houdini-ringparticles"
            target="_blank"
            rel="noopener noreferrer">CSS Houdini Ring Particles</a
          > by Bramus.
        </li>
        <li>
          Built with <a
            href="https://astro.build"
            target="_blank"
            rel="noopener noreferrer">Astro</a
          > and <a
            href="https://tailwindcss.com"
            target="_blank"
            rel="noopener noreferrer">Tailwind CSS</a
          >.
        </li>
      </ul>
    </div>
  </Section>
</Layout>
