---
import "@/styles/global.css";

import CSSHoudiniRingParticles from "@/components/CSSHoudiniRingParticles.astro";
import Footer from "@/components/Footer.astro";
import NavBar from "@/components/NavBar.astro";

const {
  title,
  description = "Personal portfolio of Fajar Maftuh Fadli, a DevOps Engineer.",
} = Astro.props;
---

<!doctype html>
<html
  lang="en"
  class="scrollbar scroll-smooth bg-black leading-relaxed text-slate-400 scrollbar-thumb-gray-900/75 scrollbar-track-transparent selection:bg-slate-800/80"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto+Mono&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <NavBar />
    <div class="flex flex-1 flex-col px-7 py-12">
      <main class="flex flex-1 flex-col items-start justify-center *:w-full">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<CSSHoudiniRingParticles />
