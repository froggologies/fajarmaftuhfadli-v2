---
import "../styles/global.css";
const { title } = Astro.props;
---

<!doctype html>
<html
  lang="en"
  class="scrollbar bg-black leading-loose text-slate-300 scrollbar-thumb-gray-900/75 scrollbar-track-transparent"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <nav class="flex h-20 items-center justify-between p-7">
      <div class="text-2xl font-bold"><a href="/">FMF</a></div>
      <ul class="flex space-x-4 font-semibold">
        <li class="hover:text-white">
          <a href="/background">Background</a>
        </li>
        <li class="hover:text-white">
          <a href="/projects">Projects</a>
        </li>
        <li class="hover:text-white"><a href="/skills">Skills</a></li>
      </ul>
    </nav>
    <div class="px-7">
      <div class="mx-auto max-w-2xl py-10">
        <slot />
      </div>
    </div>
  </body>
</html>

<style is:global>
  @supports (background: paint(something)) {
    @property --animation-tick {
      syntax: "<number>";
      inherits: false;
      initial-value: 0;
    }
    @property --ring-radius {
      syntax: "<number> | auto";
      inherits: false;
      initial-value: auto;
    }
    @property --ring-x {
      syntax: "<number>";
      inherits: false;
      initial-value: 50;
    }
    @property --ring-y {
      syntax: "<number>";
      inherits: false;
      initial-value: 50;
    }
    @property --ring-interactive {
      syntax: "<number>";
      inherits: false;
      initial-value: 0;
    }

    @keyframes ripple {
      0% {
        --animation-tick: 0;
      }
      100% {
        --animation-tick: 1;
      }
    }
    @keyframes ring {
      0% {
        --ring-radius: 150;
      }
      100% {
        --ring-radius: 250;
      }
    }

    body {
      --ring-radius: 100;
      --ring-thickness: 600;
      --particle-count: 80;
      --particle-rows: 25;
      --particle-size: 2;
      --particle-color: #e2e8f0; /* Subtle White/Gray */

      --particle-min-alpha: 0.05;
      --particle-max-alpha: 0.4;

      --seed: 200;

      background-image: paint(ring-particles);

      animation:
        ripple 6s linear infinite,
        ring 6s ease-in-out infinite alternate;
    }
  }
</style>

<script>
  // @ts-ignore
  if ("paintWorklet" in CSS) {
    // Register the PaintWorklet
    // @ts-ignore
    CSS.paintWorklet.addModule(
      "https://unpkg.com/css-houdini-ringparticles/dist/ringparticles.js"
    );

    let isInteractive = false;
    let targetX = 50;
    let targetY = 50;
    let currentX = 50;
    let currentY = 50;
    let isAnimating = false;

    const $body = document.body;

    // Smooth animation loop
    function updateAnimation() {
      if (!isInteractive) {
        isAnimating = false;
        return;
      }

      // Linear interpolation for smoothing (lower number = smoother/slower)
      currentX += (targetX - currentX) * 0.015;
      currentY += (targetY - currentY) * 0.015;

      $body.style.setProperty("--ring-x", currentX.toString());
      $body.style.setProperty("--ring-y", currentY.toString());

      requestAnimationFrame(updateAnimation);
    }

    window.addEventListener("pointermove", (e) => {
      // Use pageX/pageY instead of clientX/clientY so scrolling doesn't affect it
      const rawX = e.pageX / document.documentElement.scrollWidth;
      const rawY = e.pageY / document.documentElement.scrollHeight;

      // Constrain movement towards the center by damping the raw percentage
      // Maps a 0-1 coordinate to a restricted range (e.g. 35 to 65)
      targetX = 50 + (rawX - 0.5) * 30;
      targetY = 50 + (rawY - 0.5) * 30;

      if (!isInteractive) {
        $body.classList.add("interactive");
        isInteractive = true;
        $body.style.setProperty("--ring-interactive", "1");
        
        // Don't snap instantly to target; start from center and float towards it
        currentX = 50;
        currentY = 50;
        
        if (!isAnimating) {
          isAnimating = true;
          requestAnimationFrame(updateAnimation);
        }
      }
    });

    // Handle user leaving window
    document.addEventListener("pointerleave", (e) => {
      // Small delay prevents flickering if cursor leaves window accidentally
      setTimeout(() => {
        $body.classList.remove("interactive");
        isInteractive = false;
        $body.style.setProperty("--ring-x", "50");
        $body.style.setProperty("--ring-y", "50");
        $body.style.setProperty("--ring-interactive", "0");
      }, 100);
    });
  }
</script>
