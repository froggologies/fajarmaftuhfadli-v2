---
import "../styles/global.css";
const { title } = Astro.props;
---

<!doctype html>
<html
  lang="en"
  class="scrollbar bg-black leading-loose text-slate-400 scrollbar-thumb-gray-900/75 scrollbar-track-transparent selection:rounded-sm selection:bg-slate-800 selection:text-slate-100 [&_a]:text-slate-50 [&_a]:transition-colors [&_a]:duration-300 [&_a]:hover:text-blue-400"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <nav class="flex h-20 items-center justify-between p-7">
      <div class="text-2xl font-bold">
        <a href="/"
          ><span class="inline-block -scale-x-100 transform">F</span>MF</a
        >
      </div>
      <ul class="flex space-x-4 font-semibold">
        <li>
          <a href="/background">Background</a>
        </li>
        <li>
          <a href="/projects">Projects</a>
        </li>
        <li><a href="/skills">Skills</a></li>
      </ul>
    </nav>
    <div class="px-7">
      <div class="mx-auto max-w-2xl py-10">
        <slot />
      </div>
    </div>
  </body>
</html>

<style is:global>
  @supports (background: paint(something)) {
    @property --animation-tick {
      syntax: "<number>";
      inherits: false;
      initial-value: 0;
    }
    @property --ring-radius {
      syntax: "<number> | auto";
      inherits: false;
      initial-value: auto;
    }
    @property --ring-x {
      syntax: "<number>";
      inherits: false;
      initial-value: 50;
    }
    @property --ring-y {
      syntax: "<number>";
      inherits: false;
      initial-value: 50;
    }
    @property --ring-interactive {
      syntax: "<number>";
      inherits: false;
      initial-value: 0;
    }

    @keyframes ripple {
      0% {
        --animation-tick: 0;
      }
      100% {
        --animation-tick: 1;
      }
    }
    @keyframes ring {
      0% {
        --ring-radius: 150;
      }
      100% {
        --ring-radius: 250;
      }
    }

    body {
      --ring-radius: 100;
      --ring-thickness: 600;
      --particle-count: 80;
      --particle-rows: 25;
      --particle-size: 2;
      --particle-color: #51a2ff; /* blue 400 */

      --particle-min-alpha: 0.05;
      --particle-max-alpha: 0.4;

      --seed: 200;

      background-image: paint(ring-particles);

      animation:
        ripple 6s linear infinite,
        ring 6s ease-in-out infinite alternate;
    }
  }
</style>

<script>
  // @ts-ignore
  if ("paintWorklet" in CSS) {
    // Register the PaintWorklet
    // @ts-ignore
    CSS.paintWorklet.addModule(
      "https://unpkg.com/css-houdini-ringparticles/dist/ringparticles.js",
    );

    let isInteractive = false;
    let targetX = 50;
    let targetY = 50;
    let currentX = 50;
    let currentY = 50;
    let isAnimating = false;

    const $body = document.body;

    // Smooth animation loop — runs whether interactive or drifting back to center
    function updateAnimation() {
      const lerpSpeed = isInteractive ? 0.015 : 0.008; // slower drift back to center

      currentX += (targetX - currentX) * lerpSpeed;
      currentY += (targetY - currentY) * lerpSpeed;

      $body.style.setProperty("--ring-x", currentX.toString());
      $body.style.setProperty("--ring-y", currentY.toString());

      const dx = Math.abs(targetX - currentX);
      const dy = Math.abs(targetY - currentY);

      // Keep running until close enough to target (covers both tracking & drift-back)
      if (dx > 0.01 || dy > 0.01) {
        requestAnimationFrame(updateAnimation);
      } else {
        isAnimating = false;
      }
    }

    window.addEventListener("pointermove", (e) => {
      // Use pageX/pageY so scrolling doesn't affect position
      const rawX = e.pageX / document.documentElement.scrollWidth;
      const rawY = e.pageY / document.documentElement.scrollHeight;

      // Constrain movement: maps 0–1 => ~35–65 so ring stays near center
      targetX = 50 + (rawX - 0.5) * 30;
      targetY = 50 + (rawY - 0.5) * 30;

      if (!isInteractive) {
        $body.classList.add("interactive");
        isInteractive = true;
        $body.style.setProperty("--ring-interactive", "1");

        // Don't snap to cursor — float gently towards it from current position
        if (!isAnimating) {
          isAnimating = true;
          requestAnimationFrame(updateAnimation);
        }
      }
    });

    // When cursor leaves the window, drift back to center smoothly — no snap
    document.addEventListener("pointerleave", () => {
      $body.classList.remove("interactive");
      isInteractive = false;
      $body.style.setProperty("--ring-interactive", "0");

      // Reset target to center; the rAF loop will smoothly drift there
      targetX = 50;
      targetY = 50;

      if (!isAnimating) {
        isAnimating = true;
        requestAnimationFrame(updateAnimation);
      }
    });
  }
</script>
