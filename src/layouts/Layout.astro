---
import "@/styles/global.css";

import CSSHoudiniRingParticles from "@/components/CSSHoudiniRingParticles.astro";

const { title } = Astro.props;
---

<!doctype html>
<html
  lang="en"
  class="scrollbar bg-black leading-loose text-slate-400 scrollbar-thumb-gray-900/75 scrollbar-track-transparent selection:rounded-sm selection:bg-slate-800 selection:text-slate-100 [&_a]:text-slate-50 [&_a]:transition-colors [&_a]:duration-300 [&_a]:hover:text-blue-400"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <nav class="flex h-20 items-center justify-between p-7">
      <div class="text-2xl font-bold">
        <a href="/"
          ><span class="inline-block -scale-x-100 transform">F</span>MF</a
        >
      </div>
      <ul class="flex space-x-4 font-semibold">
        <li>
          <a href="/background">Background</a>
        </li>
        <li>
          <a href="/projects">Projects</a>
        </li>
        <li><a href="/skills">Skills</a></li>
      </ul>
    </nav>
    <div class="px-7">
      <div class="mx-auto max-w-2xl py-10">
        <slot />
      </div>
    </div>
  </body>
</html>

<CSSHoudiniRingParticles />
